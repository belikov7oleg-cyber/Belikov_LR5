# БЛОК 1: ОПРЕДЕЛЕНИЕ ПАКЕТОВ
# Базовый синтаксис Nix для определения набора зависимостей
{ pkgs }: {
  # pkgs - это набор всех доступных пакетов в Nix-репозитории
  # Фигурные скобки определяют набор (set) пакетов для установки
# БЛОК 2: СПИСОК ЗАВИСИМОСТЕЙ (DEPS)
# Перечисление всех системных пакетов, необходимых для работы проекта
  deps = [
    # БЛОК 2.1: ПАКЕТ PRYBAR-PYTHON310
    # Обеспечивает интеграцию Python 3.10 с отладчиком prybar
    # Позволяет использовать расширенные возможности отладки в Replit
    pkgs.replitPackages.prybar-python310
    # БЛОК 2.2: ПАКЕТ STDERRED
    # Библиотека для подсветки сообщений в stderr (поток ошибок)
    # Делает вывод ошибок в терминале более читаемым и наглядным
    pkgs.replitPackages.stderred
  ];
}
